# S.E.M (SSL Expiry Monitor) — .gitignore

# ── Node / Vite ──────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.*
!.env.example

# ── VS Code ───────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# ── OS junk ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── AI Agent / Antigravity ────────────────────────────────────
# .agents is a symlink — tracked via .git/info/exclude, not here
# .claude contains local Claude skill symlinks and local settings
# .tmp contains local smoke-test/bootstrap artifacts
.claude/
.tmp/
# AGENTS.md is intentionally committed for Codex visibility
STATE.json
.forensics/

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# ── Firebase ─────────────────────────────────────────────────
.firebase/
firebase-debug.log
firestore-debug.log
